{
  "name": "raceedge",
  "version": "1.0.0",
  "description": "Greyhound-first daily scan board with explicit bet tracking",
  "scripts": {
    "start": "node server/index.js",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node --watch server/index.js",
    "client": "vite",
    "build": "vite build",
    "test": "npm run test:server && npm run test:ui",
    "test:server": "node --test server/test/database.test.js server/test/predictor.test.js server/test/scraper.test.js server/test/analyst.test.js server/test/index.test.js",
    "test:ui": "vitest run --environment jsdom",
    "test:db": "node --test server/test/database.test.js",
    "test:analyst": "node --test server/test/analyst.test.js",
    "test:index": "node --test server/test/index.test.js",
    "test:predictor": "node --test server/test/predictor.test.js",
    "test:scraper": "node --test server/test/scraper.test.js"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "cheerio": "^1.0.0",
    "cors": "^2.8.5",
    "express": "^4.18.3",
    "puppeteer": "^22.4.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "jsdom": "^29.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^5.1.6",
    "vitest": "^4.1.2"
  }
}
